<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="450.0" prefWidth="450.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23.0.1" fx:controller="com.pharmacy.org.pharmacy.Controllers.MainController">
    <VBox alignment="CENTER" layoutY="1.0" prefHeight="450.0" prefWidth="450.0" spacing="20" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <TextField fx:id="fieldUserName" maxWidth="350.0" prefHeight="35.0" prefWidth="250.0" promptText="Username" style="-fx-background-radius: 7; -fx-border-radius: 7;" />
        <PasswordField fx:id="passwordField" maxWidth="350.0" prefHeight="35.0" promptText="Password" style="-fx-background-radius: 7; -fx-border-radius: 7;" />
        <Button onAction="#userlogin" prefHeight="29.0" prefWidth="51.0" style="-fx-background-radius: 7; -fx-border-radius: 7;" text="Login" />
        <Label fx:id="errorMessageLabel" />
        <Label fx:id="labelUserName" />
        <Button onAction="#userSignup" style="-fx-border-radius: 7; -fx-background-radius: 7;" text="Sign Up" />
    </VBox>
</AnchorPane>
